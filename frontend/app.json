{
  "expo": {
    "name": "AgriGrow",
    "slug": "frontend",
    "version": "1.0.0",
    "scheme": "farmersapp",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-screen-new.png",
      "resizeMode": "cover",
      "backgroundColor": "#1a3d1a"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.agrigrow.farmersapp"
    },
    "android": {
      "package": "com.agrigrow.farmersapp",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#1a7a2e"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-web-browser",
      "@react-native-google-signin/google-signin"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "49debe1a-43e1-4d45-a2d3-ef6460189be9"
      }
    },
    "owner": "prithvi-farmer"
  }
}
